## Predictive Model

# ─── Predict Next-Day PnL Bucket ─────────────────────────────────────
from sklearn.ensemble import GradientBoostingClassifier
from sklearn.model_selection import cross_val_score, StratifiedKFold
from sklearn.preprocessing import LabelEncoder

# Build feature set at daily account level
features = daily_acc[['Account','date','sentiment','daily_pnl','trades','win_rate','avg_size_usd']].copy()
features = features.sort_values(['Account','date'])

# Lag features (previous day)
features['prev_pnl']      = features.groupby('Account')['daily_pnl'].shift(1)
features['prev_trades']   = features.groupby('Account')['trades'].shift(1)
features['prev_win_rate'] = features.groupby('Account')['win_rate'].shift(1)

# Target: next day PnL bucket
features['next_pnl'] = features.groupby('Account')['daily_pnl'].shift(-1)
features['target'] = pd.cut(features['next_pnl'], bins=[-np.inf, 0, 500, np.inf],
                             labels=['Loss','Small Win','Big Win'])

features = features.dropna(subset=['prev_pnl','next_pnl','target'])

# Encode sentiment
le = LabelEncoder()
features['sentiment_enc'] = le.fit_transform(features['sentiment'])

X = features[['sentiment_enc','prev_pnl','prev_trades','prev_win_rate','avg_size_usd']]
y = features['target']

clf = GradientBoostingClassifier(n_estimators=100, max_depth=3, random_state=42)
cv = StratifiedKFold(n_splits=5, shuffle=True, random_state=42)
scores = cross_val_score(clf, X, y, cv=cv, scoring='accuracy')

print(f"5-Fold CV Accuracy: {scores.mean():.3f} ± {scores.std():.3f}")
print(f"Baseline (majority class): {y.value_counts().max()/len(y):.3f}")

clf.fit(X, y)
feat_imp = pd.Series(clf.feature_importances_, index=X.columns).sort_values(ascending=False)
print("\nFeature Importances:")
print(feat_imp.round(4).to_string())

fig, ax = plt.subplots(figsize=(8, 5))
feat_imp.plot(kind='bar', ax=ax, color=ACCENT, alpha=0.85, edgecolor='white', lw=0.5)
ax.set_title('Feature Importances — PnL Bucket Predictor', fontsize=13, fontweight='bold')
ax.set_ylabel('Importance'); ax.set_xlabel('')
ax.tick_params(axis='x', rotation=30); ax.grid(axis='y', alpha=0.4)
fig.patch.set_facecolor(BG)
plt.tight_layout(); plt.savefig('chart7_feature_importance.png', dpi=150, bbox_inches='tight', facecolor=BG)
plt.show()


