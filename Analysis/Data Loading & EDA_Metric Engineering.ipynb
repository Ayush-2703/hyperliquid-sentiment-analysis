# Timestamp Alignment & Merge

# ─── Parse & Align Dates ──────────────────────────────────────────────
fg['date'] = pd.to_datetime(fg['date'])
hist['datetime'] = pd.to_datetime(hist['Timestamp IST'], format='%d-%m-%Y %H:%M')
hist['date'] = pd.to_datetime(hist['datetime'].dt.date)

merged = hist.merge(fg[['date', 'classification', 'value']], on='date', how='left')
merged = merged.dropna(subset=['classification'])

def simplify(c):
    if 'Fear' in c: return 'Fear'
    if 'Greed' in c: return 'Greed'
    return 'Neutral'

merged['sentiment'] = merged['classification'].apply(simplify)

print(f"Merged shape: {merged.shape}")
print(f"Date range  : {merged['date'].min().date()} → {merged['date'].max().date()}")
print(f"Sentiment   : {merged['sentiment'].value_counts().to_dict()}")
print(f"Unmatched   : {merged['classification'].isna().sum()} rows")

#Key Metrics Engineering

      # ─── Per-Trade Metrics ────────────────────────────────────────────────
closing = merged[merged['Closed PnL'] != 0].copy()
closing['is_winner'] = closing['Closed PnL'] > 0
closing['is_long']   = closing['Direction'].isin(['Open Long', 'Close Short', 'Buy'])

# Daily per-account aggregation
daily_acc = closing.groupby(['Account', 'date', 'sentiment', 'classification']).agg(
    daily_pnl     = ('Closed PnL', 'sum'),
    trades        = ('Closed PnL', 'count'),
    wins          = ('is_winner',  'sum'),
    avg_size_usd  = ('Size USD',   'mean'),
    total_fee     = ('Fee',        'sum'),
).reset_index()
daily_acc['win_rate'] = daily_acc['wins'] / daily_acc['trades']

# Trader-level summary
trader = daily_acc.groupby('Account').agg(
    total_pnl      = ('daily_pnl',    'sum'),
    total_trades   = ('trades',        'sum'),
    avg_win_rate   = ('win_rate',      'mean'),
    avg_trade_size = ('avg_size_usd',  'mean'),
    trading_days   = ('date',          'nunique'),
    total_fee      = ('total_fee',     'sum'),
).reset_index()

ls = merged[merged['Direction'].isin(['Open Long', 'Open Short'])].groupby('Account').agg(
    longs=('Direction', lambda x: (x == 'Open Long').sum()),
    shorts=('Direction', lambda x: (x == 'Open Short').sum()),
).reset_index()
ls['ls_ratio'] = (ls['longs'] + 1) / (ls['shorts'] + 1)
trader = trader.merge(ls, on='Account', how='left')

# Segments
trader['freq_segment'] = pd.qcut(trader['total_trades'], q=3,
    labels=['Low Frequency', 'Mid Frequency', 'High Frequency'])
trader['size_segment'] = pd.qcut(trader['avg_trade_size'], q=3,
    labels=['Low Size', 'Mid Size', 'High Size'])
trader['wr_segment']   = pd.qcut(trader['avg_win_rate'], q=3,
    labels=['Inconsistent', 'Moderate', 'Consistent Winner'])

print(f"Closing trades  : {len(closing):,}")
print(f"Daily obs        : {len(daily_acc):,}")
print(f"Unique accounts  : {len(trader)}")
print()
print(daily_acc.describe().round(2))

      
