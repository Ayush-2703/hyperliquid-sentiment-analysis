# Analysis
# Q1. Does performance differ between Fear vs Greed days?

# ─── Chart 1: PnL & Win Rate by Sentiment ────────────────────────────
fig, axes = plt.subplots(1, 2, figsize=(14, 6))
fig.suptitle('Chart 1 — PnL & Win Rate by Market Sentiment',
             fontsize=16, fontweight='bold')

# Median daily PnL
pnl_sent = daily_acc.groupby('sentiment')['daily_pnl'].agg(['mean', 'sem', 'median']).reindex(SENT_ORDER)
bars = axes[0].bar(SENT_ORDER, pnl_sent['median'],
                   color=[COLORS[s] for s in SENT_ORDER], width=0.5, alpha=0.9,
                   edgecolor='white', linewidth=0.5)
axes[0].errorbar(SENT_ORDER, pnl_sent['median'], yerr=pnl_sent['sem']*1.96,
                 fmt='none', color='white', capsize=6, linewidth=1.5)
for bar, val in zip(bars, pnl_sent['median']):
    axes[0].text(bar.get_x()+bar.get_width()/2, bar.get_height()+5,
                 f'\${val:.0f}', ha='center', va='bottom', fontsize=11, fontweight='bold')
axes[0].set_title('Median Daily PnL per Account', fontsize=13)
axes[0].set_ylabel('USD'); axes[0].axhline(0, color='white', lw=0.8, ls='--', alpha=0.6)
axes[0].grid(axis='y', alpha=0.4)

# Win rate
wr_sent = daily_acc.groupby('sentiment')['win_rate'].mean().reindex(SENT_ORDER)
bars2 = axes[1].bar(SENT_ORDER, wr_sent*100,
                    color=[COLORS[s] for s in SENT_ORDER], width=0.5, alpha=0.9,
                    edgecolor='white', linewidth=0.5)
for bar, val in zip(bars2, wr_sent*100):
    axes[1].text(bar.get_x()+bar.get_width()/2, val+0.5,
                 f'{val:.1f}%', ha='center', va='bottom', fontsize=11, fontweight='bold')
axes[1].axhline(50, color='white', lw=1, ls='--', alpha=0.7, label='50% line')
axes[1].set_title('Average Win Rate by Sentiment', fontsize=13)
axes[1].set_ylabel('Win Rate (%)'); axes[1].set_ylim(0, 100)
axes[1].grid(axis='y', alpha=0.4); axes[1].legend(fontsize=10)

plt.tight_layout(); plt.savefig('chart1_pnl_winrate.png', dpi=150, bbox_inches='tight', facecolor=BG)
plt.show()

print("\n📊 FINDING: Greed days show the highest median PnL ($909), while Fear days have")
print("the highest mean PnL ($7,161) driven by a few large winning trades.")
print("Win rates are consistently high (84-86%) across all sentiments.")

# Q2. Do traders change behavior based on sentiment?

# ─── Chart 2: Trader Behavior by Sentiment ───────────────────────────
fig, axes = plt.subplots(1, 3, figsize=(18, 6))
fig.suptitle('Chart 2 — Trader Behavior Across Sentiment Regimes', fontsize=16, fontweight='bold')

freq = daily_acc.groupby('sentiment')['trades'].mean().reindex(SENT_ORDER)
axes[0].bar(SENT_ORDER, freq, color=[COLORS[s] for s in SENT_ORDER], width=0.5, alpha=0.9, edgecolor='white', lw=0.5)
for i, (s, v) in enumerate(freq.items()):
    axes[0].text(i, v+0.1, f'{v:.1f}', ha='center', va='bottom', fontsize=12, fontweight='bold')
axes[0].set_title('Avg Trades per Account/Day', fontsize=13); axes[0].set_ylabel('Trade Count')
axes[0].grid(axis='y', alpha=0.4)

size = daily_acc.groupby('sentiment')['avg_size_usd'].mean().reindex(SENT_ORDER)
axes[1].bar(SENT_ORDER, size/1000, color=[COLORS[s] for s in SENT_ORDER], width=0.5, alpha=0.9, edgecolor='white', lw=0.5)
for i, (s, v) in enumerate(size.items()):
    axes[1].text(i, v/1000+0.2, f'\${v/1000:.1f}K', ha='center', va='bottom', fontsize=12, fontweight='bold')
axes[1].set_title('Avg Trade Size (USD)', fontsize=13); axes[1].set_ylabel('Size (USD thousands)')
axes[1].grid(axis='y', alpha=0.4)

ls_daily = merged[merged['Direction'].isin(['Open Long','Open Short'])].groupby(['date','sentiment']).apply(
    lambda x: pd.Series({'longs':(x['Direction']=='Open Long').sum(),
                         'shorts':(x['Direction']=='Open Short').sum()})
).reset_index()
ls_daily['ls_ratio'] = ls_daily['longs'] / ls_daily['shorts'].replace(0, np.nan)
ls_mean = ls_daily.groupby('sentiment')['ls_ratio'].mean().reindex(SENT_ORDER)
axes[2].bar(SENT_ORDER, ls_mean, color=[COLORS[s] for s in SENT_ORDER], width=0.5, alpha=0.9, edgecolor='white', lw=0.5)
for i, (s, v) in enumerate(ls_mean.items()):
    axes[2].text(i, v+0.05, f'{v:.2f}x', ha='center', va='bottom', fontsize=12, fontweight='bold')
axes[2].axhline(1, color='white', lw=1, ls='--', alpha=0.7, label='1:1 parity')
axes[2].set_title('Long/Short Ratio (Opens)', fontsize=13); axes[2].set_ylabel('Ratio')
axes[2].grid(axis='y', alpha=0.4); axes[2].legend(fontsize=10)

plt.tight_layout(); plt.savefig('chart2_behavior.png', dpi=150, bbox_inches='tight', facecolor=BG)
plt.show()

print("\n📊 KEY BEHAVIORAL SHIFTS:")
print(f"  • Trade frequency:  Fear={freq['Fear']:.1f}  Neutral={freq['Neutral']:.1f}  Greed={freq['Greed']:.1f}")
print(f"  • Avg trade size:   Fear=\${size['Fear']/1000:.1f}K  Greed=\${size['Greed']/1000:.1f}K (+{(size['Fear']/size['Greed']-1)*100:.0f}% larger during Fear)")
print(f"  • L/S ratio:        Fear={ls_mean['Fear']:.1f}x  Greed={ls_mean['Greed']:.1f}x  (Traders BUY THE DIP during Fear)")

# Q3. Trader Segmentation

# ─── Chart 3: Trader Segments ────────────────────────────────────────
fig, axes = plt.subplots(1, 3, figsize=(18, 6))
fig.suptitle('Chart 3 — Trader Segmentation: Median Total PnL by Segment', fontsize=16, fontweight='bold')

seg_pal = ['#FF6B6B', '#FFD43B', '#51CF66']
for ax, seg_col, title in zip(axes,
    ['freq_segment', 'wr_segment', 'size_segment'],
    ['Trade Frequency', 'Consistency (Win Rate)', 'Avg Position Size']):
    seg_pnl = trader.groupby(seg_col)['total_pnl'].median().reset_index()
    bars = ax.bar(range(len(seg_pnl)), seg_pnl['total_pnl']/1000,
                  color=seg_pal, alpha=0.9, edgecolor='white', lw=0.5, width=0.5)
    ax.set_xticks(range(len(seg_pnl)))
    ax.set_xticklabels(seg_pnl[seg_col], fontsize=10)
    for bar, (_, row) in zip(bars, seg_pnl.iterrows()):
        ypos = row['total_pnl']/1000
        ax.text(bar.get_x()+bar.get_width()/2, ypos+(2 if ypos>=0 else -15),
                f'\${ypos:.0f}K', ha='center', va='bottom', fontsize=11, fontweight='bold')
    ax.set_title(f'Segment: {title}', fontsize=13); ax.set_ylabel('Median Total PnL ($K)')
    ax.axhline(0, color='white', lw=0.8, ls='--', alpha=0.6); ax.grid(axis='y', alpha=0.4)

plt.tight_layout(); plt.savefig('chart3_segments.png', dpi=150, bbox_inches='tight', facecolor=BG)
plt.show()

print("\n📊 SEGMENT FINDINGS:")
for seg in ['freq_segment', 'wr_segment', 'size_segment']:
    print(f"\n  {seg}:")
    print(trader.groupby(seg)[['total_pnl','avg_win_rate','total_trades']].median().round(2).to_string())

# ─── Chart 4: Cumulative PnL Over Time ───────────────────────────────
fig, ax = plt.subplots(figsize=(16, 6))
fig.suptitle('Chart 4 — Cumulative PnL Over Time by Sentiment Regime', fontsize=15, fontweight='bold')

daily_total = daily_acc.groupby('date')['daily_pnl'].sum().reset_index().sort_values('date')
daily_total['cumulative_pnl'] = daily_total['daily_pnl'].cumsum()
sent_map = merged.groupby('date')['sentiment'].first()
daily_total['sentiment'] = daily_total['date'].map(sent_map)

ax.plot(daily_total['date'], daily_total['cumulative_pnl']/1e6, color=ACCENT, lw=2, zorder=3, label='Cumulative PnL')
for i in range(len(daily_total)-1):
    s = daily_total.iloc[i]['sentiment']
    if pd.notna(s):
        ax.axvspan(daily_total.iloc[i]['date'], daily_total.iloc[i+1]['date'],
                   alpha=0.15, color=COLORS.get(s, 'gray'), zorder=1)

legend_elements = [Patch(facecolor=COLORS[s], alpha=0.5, label=f'{s} Days') for s in SENT_ORDER]
legend_elements += [plt.Line2D([0],[0], color=ACCENT, lw=2, label='Cumulative PnL')]
ax.legend(handles=legend_elements, fontsize=11, loc='upper left')
ax.set_xlabel('Date', fontsize=12); ax.set_ylabel('Cumulative PnL (USD Millions)', fontsize=12)
ax.grid(alpha=0.3); ax.axhline(0, color='white', lw=0.8, ls='--', alpha=0.5)

plt.tight_layout(); plt.savefig('chart4_cumulative.png', dpi=150, bbox_inches='tight', facecolor=BG)
plt.show()


# ─── Chart 5: PnL Distribution by Classification ─────────────────────
cl_order = ['Extreme Fear', 'Fear', 'Neutral', 'Greed', 'Extreme Greed']
cl_colors = {'Extreme Fear':'#c0392b', 'Fear':'#e74c3c', 'Neutral':'#f1c40f',
             'Greed':'#2ecc71', 'Extreme Greed':'#27ae60'}

fig, axes = plt.subplots(1, 2, figsize=(16, 6))
fig.suptitle('Chart 5 — PnL Distribution & Drawdown by Sentiment', fontsize=16, fontweight='bold')

merged2 = daily_acc.merge(merged[['date','classification']].drop_duplicates('date'), on='date', how='left')
bp_data = [merged2[merged2['classification']==c]['daily_pnl'].clip(-2000, 2000).dropna() for c in cl_order]
bp = axes[0].boxplot(bp_data, labels=cl_order, patch_artist=True,
                     medianprops=dict(color='white', lw=2),
                     whiskerprops=dict(color=TEXT), capprops=dict(color=TEXT),
                     flierprops=dict(marker='.', color='gray', alpha=0.3))
for patch, c in zip(bp['boxes'], cl_order):
    patch.set_facecolor(cl_colors[c]); patch.set_alpha(0.8)
axes[0].set_title('Daily PnL Distribution (clipped ±$2K)', fontsize=12)
axes[0].set_ylabel('Daily PnL (USD)'); axes[0].axhline(0, color='white', lw=0.8, ls='--', alpha=0.7)
axes[0].tick_params(axis='x', rotation=15); axes[0].grid(axis='y', alpha=0.4)

drawdown = merged2.groupby('classification').apply(lambda x: (x['daily_pnl'] < 0).mean()*100).reindex(cl_order)
bars = axes[1].bar(cl_order, drawdown, color=[cl_colors[c] for c in cl_order], alpha=0.9, edgecolor='white', lw=0.5)
for bar, val in zip(bars, drawdown):
    axes[1].text(bar.get_x()+bar.get_width()/2, val+0.5, f'{val:.1f}%',
                 ha='center', va='bottom', fontsize=10, fontweight='bold')
axes[1].set_title('% of Days with Negative PnL (Drawdown Proxy)', fontsize=12)
axes[1].set_ylabel('% Loss Days'); axes[1].tick_params(axis='x', rotation=15)
axes[1].grid(axis='y', alpha=0.4)

plt.tight_layout(); plt.savefig('chart5_distribution.png', dpi=150, bbox_inches='tight', facecolor=BG)
plt.show()

print("\n📊 DRAWDOWN RATES:")
print(drawdown.to_string())



# ─── Chart 6: Segment × Sentiment Interaction ────────────────────────
daily_with_seg = daily_acc.merge(trader[['Account','size_segment','freq_segment']], on='Account', how='left')

fig, axes = plt.subplots(1, 2, figsize=(16, 6))
fig.suptitle('Chart 6 — Sentiment × Trader Segment Interaction', fontsize=15, fontweight='bold')

for ax, seg_col, title in zip(axes, ['size_segment','freq_segment'],
                               ['Position Size Segment', 'Trade Frequency Segment']):
    pivot = daily_with_seg.groupby([seg_col,'sentiment'])['daily_pnl'].median().unstack('sentiment').reindex(columns=SENT_ORDER)
    x = np.arange(len(pivot)); w = 0.25
    for i, sent in enumerate(SENT_ORDER):
        ax.bar(x + i*w, pivot[sent], w, label=sent, color=COLORS[sent], alpha=0.85, edgecolor='white', lw=0.4)
    ax.set_xticks(x+w); ax.set_xticklabels(pivot.index, fontsize=11)
    ax.set_title(title, fontsize=13); ax.set_ylabel('Median Daily PnL (USD)')
    ax.axhline(0, color='white', lw=0.8, ls='--', alpha=0.6)
    ax.legend(title='Sentiment', fontsize=10); ax.grid(axis='y', alpha=0.4)

plt.tight_layout(); plt.savefig('chart6_interaction.png', dpi=150, bbox_inches='tight', facecolor=BG)
plt.show()



